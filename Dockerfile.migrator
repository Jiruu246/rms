# --- Stage 1: Build ---
FROM golang:1.25-alpine AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .

# Build the migration runner (adjust path to your migration main file)
RUN CGO_ENABLED=0 GOOS=linux go build -o migrator ./cmd/migrate

# --- Stage 2: Runtime ---
FROM alpine:latest
RUN apk --no-cache add ca-certificates

WORKDIR /home/appuser/

COPY --from=builder /app/migrator .

# Use a non-root user
RUN adduser -D appuser
USER appuser

# Standard command to run migrations
ENTRYPOINT ["./migrator"]